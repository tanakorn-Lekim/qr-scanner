<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>QR Code Scanner</title>
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <style>
      :root {
        font-family: Arial, sans-serif;
        color: #172033;
        background: #f6f7fb;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 20px;
      }

      main {
        width: min(100%, 520px);
        background: #ffffff;
        border: 1px solid #dfe4ee;
        border-radius: 8px;
        padding: 18px;
        box-shadow: 0 10px 28px rgba(28, 39, 61, 0.08);
      }

      h1 {
        margin: 0 0 14px;
        font-size: 22px;
      }

      #reader {
        width: 100%;
        overflow: hidden;
        border: 1px solid #cfd6e4;
        border-radius: 8px;
        background: #eef2f7;
      }

      .actions {
        display: flex;
        gap: 10px;
        margin-top: 14px;
      }

      button {
        flex: 1;
        border: 0;
        border-radius: 6px;
        padding: 12px 14px;
        font-size: 15px;
        cursor: pointer;
      }

      #startButton {
        color: #ffffff;
        background: #1664d9;
      }

      #stopButton {
        color: #172033;
        background: #e8edf5;
      }

      #result {
        margin-top: 14px;
        padding: 12px;
        min-height: 48px;
        border-radius: 6px;
        background: #f0f4fa;
        word-break: break-word;
      }

      .label {
        display: block;
        margin-bottom: 4px;
        color: #556176;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Scan QR Code</h1>
      <div id="reader"></div>

      <div class="actions">
        <button id="startButton" type="button">Start camera</button>
        <button id="stopButton" type="button">Stop</button>
      </div>

      <div id="result">
        <span class="label">Scanned value</span>
        <span id="resultText">No data yet</span>
      </div>
    </main>

    <script>
      const APPS_SCRIPT_URL = 'https://script.google.com/a/macros/siamintermold.com/s/AKfycbyYhiYZ3jGOwsvtKkZHTeqrRMvxhgtOzFUvgrxFJnEZSQrh8-abU_rh7-NDpQT0wbjL/exec';
      const readerId = 'reader';
      const scanner = new Html5Qrcode(readerId);
      const startButton = document.getElementById('startButton');
      const stopButton = document.getElementById('stopButton');
      const resultText = document.getElementById('resultText');
      let isScanning = false;

      async function startScanner() {
        if (isScanning) return;

        if (!window.isSecureContext || !navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
          resultText.textContent = 'Open this page through HTTPS or localhost to use the camera.';
          return;
        }

        try {
          await scanner.start(
            { facingMode: 'environment' },
            {
              fps: 10,
              qrbox: function(viewfinderWidth, viewfinderHeight) {
                const size = Math.floor(Math.min(viewfinderWidth, viewfinderHeight) * 0.72);
                return { width: size, height: size };
              }
            },
            onScanSuccess
          );
          isScanning = true;
          resultText.textContent = 'Waiting for QR code...';
        } catch (error) {
          resultText.textContent = 'Cannot open camera: ' + (error.message || error);
        }
      }

      async function stopScanner() {
        if (!isScanning) return;

        await scanner.stop();
        await scanner.clear();
        isScanning = false;
      }

      async function onScanSuccess(decodedText) {
        resultText.textContent = decodedText;
        await stopScanner();
        sendToAppsScript(decodedText);
      }

      function sendToAppsScript(value) {
        if (!APPS_SCRIPT_URL || APPS_SCRIPT_URL.indexOf('PASTE_') === 0) {
          resultText.textContent = value + ' (Set APPS_SCRIPT_URL to send this value.)';
          return;
        }

        if (navigator.sendBeacon) {
          const payload = new Blob([value], { type: 'text/plain;charset=utf-8' });
          const queued = navigator.sendBeacon(APPS_SCRIPT_URL, payload);

          if (queued) {
            resultText.textContent = value + ' (sent)';
            return;
          }
        }

        const beaconUrl = APPS_SCRIPT_URL + '?value=' + encodeURIComponent(value) + '&t=' + Date.now();
        const beacon = new Image();
        beacon.src = beaconUrl;
        resultText.textContent = value + ' (sent)';
      }

      startButton.addEventListener('click', startScanner);
      stopButton.addEventListener('click', stopScanner);
    </script>
  </body>
</html>
